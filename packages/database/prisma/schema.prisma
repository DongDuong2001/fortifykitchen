datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

// Payment state of an Order or Subscription as tracked by staff — mirrors
// the 3-step flow used in the original app (Chưa thanh toán / Đã cọc / Đã
// thanh toán). Distinct from the generic Payment ledger's PaymentStatus
// below, which tracks individual transaction attempts, not the running
// balance state of an order/subscription.
enum PaymentState {
  UNPAID // Chưa thanh toán
  DEPOSIT // Đã cọc
  PAID // Đã thanh toán
}

// Unified order lifecycle — modeled on the Shopee-style flow so both a
// one-off order and a subscription-generated occurrence share one set of
// stages instead of two parallel status enums. COMPLETED is the only status
// that ever triggers a SubscriptionPool deduction (see OrdersService); every
// other transition is a pure status change.
enum OrderStatus {
  PENDING_CONFIRMATION // Chờ xác nhận — just placed/generated, staff hasn't accepted it yet
  CONFIRMED // Đã xác nhận — staff accepted it
  PREPARING // Đang chuẩn bị — kitchen is prepping it
  OUT_FOR_DELIVERY // Đang giao — left the kitchen
  COMPLETED // Hoàn thành — delivered/picked up
  CANCELLED // Đã hủy
}

// Where an Order came from — a one-off order placed directly, or an
// occurrence materialized from a Subscription's volume schedule. Orders of
// either source share the exact same table/status lifecycle now; this is
// purely a display/filter tag, derivable from subscriptionId != null but
// kept as an explicit column so queries/filters don't have to re-derive it.
enum OrderSource {
  ONE_OFF
  SUBSCRIPTION
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CustomPlanRequestStatus {
  PENDING // Chờ tư vấn — customer submitted, admin hasn't reviewed yet
  REVIEWED // Admin looked at it, still working out a match
  MATCHED // Admin created/linked a Subscription for this request
  DECLINED
}

// Whether an Order was fulfilled from ready-made stock (no prep needed,
// delivered/picked up right away) or needs the kitchen to prep it first.
// Computed automatically at order-creation time from each line item's
// MenuItem.stockQuantity — never set directly by the client.
enum OrderFulfillmentType {
  IMMEDIATE // every line item had enough stockQuantity; stock was decremented
  SCHEDULED // at least one line item needed prep; no stock was touched
}

enum OrderType {
  IMMEDIATE_DELIVERY
  PRE_ORDER
}

enum Protein {
  CHICKEN
  BEEF
  SHRIMP
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  STRIPE
  CASH_ON_DELIVERY
  BANK_TRANSFER
  WALLET // paid from Customer.walletBalance — see docs/plan-and-credit-design.md
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  firstName    String
  lastName     String
  passwordHash String
  role         UserRole  @default(CUSTOMER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customer     Customer?

  // Better Auth sessions
  sessions Session[]
  accounts Account[]

  @@index([email])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id           String    @id @default(uuid())
  userId       String
  providerId   String
  accountId    String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

// Customer is intentionally NOT tied to a required User account — today the
// business has no customer self-serve login, staff manage customers purely
// by name/phone/Zalo. userId is optional so a customer portal can be added
// later (e.g. via Better Auth) without remodeling this table.
model Customer {
  id            String         @id @default(uuid())
  userId        String?        @unique
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  phone         String?
  zalo          String?
  address       String?
  notes         String?

  // Spendable balance in whole VND, topped up by buying a SubscriptionPlan
  // (see SubscriptionPlan) and spent on one-off orders (PaymentMethod.WALLET)
  // or in full toward a staff-built Subscription from an approved
  // CustomPlanRequest. Never negative — any wallet-funded payment is
  // rejected outright if this is short, no admin override. See
  // docs/plan-and-credit-design.md.
  walletBalance Int @default(0)

  // Recurring membership discount, granted directly on Customer rather than
  // as a redeemable Discount code — buying a SubscriptionPlan with
  // voucherPercent > 0 sets this (see SubscriptionPlansService.confirmPurchase)
  // and it applies silently to every order until planDiscountEndsAt, no code
  // to type, nothing to "redeem." Decided: this REPLACES the earlier
  // single-use plan-purchase voucher design entirely — a customer can only
  // ever hold one plan's discount at a time (see the purchase() guard, which
  // blocks buying a new plan while planDiscountEndsAt is still in the
  // future; upgrading mid-term is a staff-assisted action, not self-serve).
  planDiscountPercent Int       @default(0)
  planDiscountEndsAt  DateTime?

  orders             Order[]
  subscriptions      Subscription[]
  customPlanRequests CustomPlanRequest[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([phone])
}

// Kept for future menu organization (e.g. combos, sides) — not used by the
// current protein/flavor/size model, so MenuItem.categoryId is optional.
model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  menuItems   MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// A sellable SKU: one protein + flavor + portion size combination.
// e.g. chicken / xá xíu / 150g. price is in whole VND (no subunit).
model MenuItem {
  id          String    @id @default(uuid())
  protein     Protein
  flavor      String
  sizeGrams   Int
  price       Int
  isAvailable Boolean   @default(true)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // How many portions of this exact SKU are prepped and ready to go right
  // now — decremented when an Order is fulfilled IMMEDIATE, restored if
  // that order is later cancelled/deleted before delivery. 0 means "needs
  // prep" for this item (the normal/original behavior).
  stockQuantity Int @default(0)

  // Optional customer-facing copy/photo — not used by the admin tool today
  // but needed by the customer-web storefront.
  description String?
  imageUrl    String?

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([protein])
  @@index([categoryId])
}

// A single order for a single delivery date — covers BOTH a one-off order
// placed directly AND an occurrence materialized from a Subscription's
// volume schedule (subscriptionId set, source SUBSCRIPTION). Unifying these
// into one model/status lifecycle is deliberate: previously a subscription
// occurrence was a separate `Delivery` row with its own status enum, which
// meant every admin list view (Orders / Orders from Subscriptions /
// Deliveries) had to merge two tables client- or service-side. Now it's one
// table, one status enum (see OrderStatus), filterable by `source`.
//
// Line items snapshot the protein/flavor/size/unitPrice at order time (menu
// prices can change later without altering historical orders), matching the
// discount engine in packages/shared which recomputes
// subtotal/discount/total from the exact same line-item shape.
model Order {
  id              String        @id @default(uuid())
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String // denormalized snapshot; survives customer deletion
  deliveryDate    DateTime
  paymentStatus   PaymentState  @default(UNPAID)
  status          OrderStatus   @default(PENDING_CONFIRMATION)
  fulfillmentType OrderFulfillmentType @default(SCHEDULED)
  type            OrderType     @default(IMMEDIATE_DELIVERY)
  systemNotes     String?
  paymentMethod   PaymentMethod @default(CASH_ON_DELIVERY)
  deliveryAddress String?
  subtotal        Int
  discountAmount  Int           @default(0)
  // Denormalized snapshot of whichever Discount.code was redeemed on this
  // order, if any — stacks additively with the automatic tier discount
  // above (both folded into discountAmount); purely for staff/customer
  // visibility into "why was this discounted." See DiscountRedemption for
  // the actual one-redemption-per-customer enforcement.
  discountCode    String?
  total           Int
  notes           String?
  items           OrderItem[]

  // Set only for orders materialized from a Subscription's volume schedule
  // (see SubscriptionsService.syncUpcomingOrders). source is a redundant but
  // explicit tag for filtering — always ONE_OFF when subscriptionId is null,
  // SUBSCRIPTION when it isn't.
  source         OrderSource   @default(ONE_OFF)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([deliveryDate])
  @@index([paymentStatus])
  @@index([fulfillmentType])
  @@index([status])
  @@index([subscriptionId])
  @@index([source])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  // Snapshot of the menu item at order time — protects historical orders
  // from later menu price/flavor changes.
  protein   Protein
  flavor    String
  sizeGrams Int
  unitPrice Int
  qty       Int

  @@index([orderId])
  @@index([menuItemId])
}

// Volume-based subscription: the customer buys a total WEIGHT per protein
// up front (e.g. 30kg chicken + 10kg beef + 5kg shrimp — see
// SubscriptionPool), not a fixed portion-count template. They separately
// choose a delivery cadence (deliveryAmountGrams delivered every
// deliveryIntervalDays); the specific flavor for each occurrence is chosen
// closer to delivery time (see Order — subscription occurrences are just
// Orders with subscriptionId set) and deducted from the matching protein's
// pool once that Order's status is actually marked COMPLETED — never at
// scheduling time. This keeps balances accurate even though the schedule
// length isn't knowable exactly up front (postponing shifts it, and real
// package sizes don't divide evenly into deliveryAmountGrams).
//
// Occurrences are NOT all generated at creation time — only ones landing
// within the next 7 days are materialized (see SubscriptionsService.
// syncUpcomingOrders), keeping the Orders list from being flooded with
// months of future placeholder rows.
//
// Subscriptions are always staff-created, never customer self-serve — see
// SubscriptionsController (ADMIN/MANAGER/STAFF only). A customer who wants
// something outside the standard catalog instead files a CustomPlanRequest,
// which staff review and turn into a Subscription (see
// CustomPlanRequest.matchedSubscriptionId).
model Subscription {
  id                   String             @id @default(uuid())
  customerId           String?
  customer             Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName         String // denormalized snapshot; survives customer deletion
  packageName          String
  totalGrams           Int // sum of pools' totalGrams at purchase time (fixed reference)
  deliveryAmountGrams  Int // target weight delivered per occurrence (across all proteins)
  deliveryIntervalDays Int // days between occurrences
  startDate            DateTime
  totalPrice           Int
  paymentStatus        PaymentState       @default(UNPAID)
  status               SubscriptionStatus @default(ACTIVE)
  postponedCount       Int                @default(0) // how many times an order has been postponed, for admin visibility

  pools              SubscriptionPool[] // one row per protein purchased, tracks remaining balance
  orders             Order[] // the materialized (rolling 7-day-ahead) schedule, as normal Orders
  customPlanRequests CustomPlanRequest[] // request(s) this subscription was created to satisfy, if any

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

// One protein's purchased balance within a volume subscription — e.g.
// "30kg CHICKEN, 12.4kg remaining". remainingGrams only ever decreases when
// an Order containing items of this protein has its status marked COMPLETED
// (OrdersService.markCompleted), never when an order is merely scheduled or
// postponed — that's what keeps postponing "conservative" (requirement:
// postponed amounts are preserved, not deducted).
model SubscriptionPool {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  protein        Protein
  totalGrams     Int
  remainingGrams Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@unique([subscriptionId, protein])
}

// A customer's ask for a plan outside the standard catalog — always starts
// as a consultation request, never a binding order. Staff review it
// (adminNotes/status), and if they build a matching Subscription for the
// customer, they link it back here via matchedSubscriptionId so there's a
// record of which request a given Subscription came from. Preferences are
// intentionally loose (arrays/optional fields, plus free-text notes) since
// this is a discovery step, not a priced line-item order — the actual
// pools/pricing get nailed down on the real Subscription once staff have
// talked to the customer.
model CustomPlanRequest {
  id           String  @id @default(uuid())
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName String
  phone        String?

  desiredProteins       Protein[] // proteins the customer is interested in, if known yet
  estimatedTotalGrams   Int? // rough total weight they're picturing, if they gave one
  preferredIntervalDays Int? // rough delivery cadence they're picturing, if they gave one
  budgetHint            Int? // rough budget in VND, if they gave one
  notes                 String? // free-text: what they actually asked for

  status     CustomPlanRequestStatus @default(PENDING)
  adminNotes String? // staff's consultation notes / reason for declining

  matchedSubscriptionId String?
  matchedSubscription   Subscription? @relation(fields: [matchedSubscriptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([matchedSubscriptionId])
}

// Coupon-style promo codes. Historically this table had two origins: (1) a
// public code an admin creates by hand (customerId null), and (2) a
// voucher auto-issued to one specific customer when they bought a
// SubscriptionPlan (customerId set, code auto-generated). Origin (2) was
// retired — SubscriptionPlan purchases now set Customer.planDiscountPercent
// / planDiscountEndsAt directly instead of minting a Discount row (see
// SubscriptionPlansService.confirmPurchase and
// docs/plan-and-credit-design.md) — so every NEW row here is admin-created.
// customerId/redemptions are kept because (a) any pre-migration voucher
// rows still exist and are still redeemable/expirable, and (b) an admin can
// still hand-create a customer-scoped code via customerId if needed.
//
// `description` is admin-facing only (never shown to the customer) so
// staff can tell codes apart at a glance — e.g. "Tết 2026 campaign,
// public" vs "Goodwill code for customer X after late delivery" — without
// having to infer origin from customerId alone.
// usageLimit/usageCount cap total redemptions across ALL customers
// (separate from the existing @@unique([discountId, customerId]) on
// DiscountRedemption, which only ever caps one customer to one use of a
// given code). usageLimit null = unlimited. usageCount is a denormalized
// counter incremented atomically in the same transaction that creates the
// DiscountRedemption row (see OrdersService.create) via a conditional
// `updateMany` guarded by `usageCount < usageLimit` — Postgres row locking
// inside that transaction is what makes the check-and-increment safe under
// concurrent redemptions, not a plain read-then-write.
model Discount {
  id          String              @id @default(uuid())
  code        String              @unique
  type        String // PERCENTAGE | FIXED
  amount      Decimal             @db.Decimal(10, 2)
  isActive    Boolean             @default(true)
  startsAt    DateTime
  endsAt      DateTime
  customerId  String? // set for a customer-scoped code (legacy plan voucher, or a hand-created one-off); null for a public code
  description String? // admin-only note on why this code exists / who it's for
  usageLimit  Int? // max total redemptions across all customers; null = unlimited
  usageCount  Int                 @default(0) // denormalized count of successful redemptions so far
  redemptions DiscountRedemption[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([code])
  @@index([customerId])
}

// Enforces "one redemption per customer" for a Discount, even a reusable
// public code (e.g. a "first order only" WELCOME10) that many different
// customers can each use once — decided: customers should NOT be able to
// re-apply the same code order after order. A personal plan-purchase
// voucher (Discount.customerId set) is additionally hard-deactivated
// (isActive: false) on redemption since it only ever had one eligible
// customer anyway; this table still logs that redemption too, for one
// consistent audit trail across both kinds of codes.
//
// The @@unique below is what actually prevents a double-redemption under
// concurrent requests — OrdersService claims this row inside the same
// transaction as order creation, and relies on the unique constraint
// throwing (rather than a racy check-then-write) to make the claim atomic.
model DiscountRedemption {
  id         String   @id @default(uuid())
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  customerId String
  orderId    String?
  createdAt  DateTime @default(now())

  @@unique([discountId, customerId])
  @@index([discountId])
  @@index([customerId])
}

// A purchasable price tier (e.g. 1,500,000đ, 3,000,000đ) — buying one
// credits Customer.walletBalance by `price` and issues that customer a
// percentage-off Discount voucher sized by `voucherPercent`. This is the
// ONLY self-serve purchase a customer can make; it never grants
// autonomous/recurring delivery by itself — that always goes through a
// CustomPlanRequest, reviewed by staff (see docs/plan-and-credit-design.md).
model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String // e.g. "Gói 1.5 triệu"
  price          Int // VND, credited 1:1 to Customer.walletBalance on purchase
  voucherPercent Int      @default(0) // % off voucher granted on purchase, admin-configurable per tier
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

// Ledger of actual payment transactions (future real payment processing).
// Distinct from Order.paymentStatus / Subscription.paymentStatus, which are
// the simple staff-tracked status shown in the UI today.
//
// Also doubles as the wallet top-up ledger: a SubscriptionPlan purchase
// creates a row here with customerId + subscriptionPlanId set (orderId/
// subscriptionId null) and starts PENDING — the customer bank-transfers the
// amount, and staff mark it COMPLETED once received, which is what actually
// credits Customer.walletBalance and issues the voucher (see
// docs/plan-and-credit-design.md). orderId/subscriptionId/customerId/
// subscriptionPlanId are deliberately plain ids (not Prisma relations),
// matching the existing loose-ledger style of this table.
model Payment {
  id                 String        @id @default(uuid())
  orderId            String?
  subscriptionId     String?
  customerId         String?
  subscriptionPlanId String?
  amount             Decimal       @db.Decimal(10, 2)
  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  transactionId      String?       @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([orderId])
  @@index([subscriptionId])
  @@index([customerId])
  @@index([subscriptionPlanId])
  @@index([status])
}

model HomeFrame {
  id        String   @id @default(uuid())
  title     String?
  imageUrl  String
  linkUrl   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

