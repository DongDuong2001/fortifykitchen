datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

// Payment state of an Order or Subscription as tracked by staff — mirrors
// the 3-step flow used in the original app (Chưa thanh toán / Đã cọc / Đã
// thanh toán). Distinct from the generic Payment ledger's PaymentStatus
// below, which tracks individual transaction attempts, not the running
// balance state of an order/subscription.
enum PaymentState {
  UNPAID // Chưa thanh toán
  DEPOSIT // Đã cọc
  PAID // Đã thanh toán
}

// Fulfillment status of a single delivery occurrence — used on both Order
// (a one-off order is itself a single delivery day) and Delivery (each
// occurrence generated by a Subscription's schedule).
enum DeliveryStatus {
  SCHEDULED
  PREPPING
  DELIVERED
  SKIPPED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// Whether an Order was fulfilled from ready-made stock (no prep needed,
// delivered/picked up right away) or needs the kitchen to prep it first.
// Computed automatically at order-creation time from each line item's
// MenuItem.stockQuantity — never set directly by the client.
enum OrderFulfillmentType {
  IMMEDIATE // every line item had enough stockQuantity; stock was decremented
  SCHEDULED // at least one line item needed prep; no stock was touched
}

enum Protein {
  CHICKEN
  BEEF
  SHRIMP
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  STRIPE
  CASH_ON_DELIVERY
  BANK_TRANSFER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  firstName    String
  lastName     String
  passwordHash String
  role         UserRole  @default(CUSTOMER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customer     Customer?

  // Better Auth sessions
  sessions Session[]
  accounts Account[]

  @@index([email])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id           String    @id @default(uuid())
  userId       String
  providerId   String
  accountId    String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

// Customer is intentionally NOT tied to a required User account — today the
// business has no customer self-serve login, staff manage customers purely
// by name/phone/Zalo. userId is optional so a customer portal can be added
// later (e.g. via Better Auth) without remodeling this table.
model Customer {
  id            String         @id @default(uuid())
  userId        String?        @unique
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  phone         String?
  zalo          String?
  address       String?
  notes         String?
  orders        Order[]
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([phone])
}

// Kept for future menu organization (e.g. combos, sides) — not used by the
// current protein/flavor/size model, so MenuItem.categoryId is optional.
model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  menuItems   MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// A sellable SKU: one protein + flavor + portion size combination.
// e.g. chicken / xá xíu / 150g. price is in whole VND (no subunit).
model MenuItem {
  id          String    @id @default(uuid())
  protein     Protein
  flavor      String
  sizeGrams   Int
  price       Int
  isAvailable Boolean   @default(true)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // How many portions of this exact SKU are prepped and ready to go right
  // now — decremented when an Order is fulfilled IMMEDIATE, restored if
  // that order is later cancelled/deleted before delivery. 0 means "needs
  // prep" for this item (the normal/original behavior).
  stockQuantity Int @default(0)

  // Optional customer-facing copy/photo — not used by the admin tool today
  // but needed by the customer-web storefront.
  description String?
  imageUrl    String?

  orderItems    OrderItem[]
  deliveryItems DeliveryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([protein])
  @@index([categoryId])
}

// A one-off order for a single delivery date. Line items snapshot the
// protein/flavor/size/unitPrice at order time (menu prices can change
// later without altering historical orders), matching the discount engine
// in packages/shared which recomputes subtotal/discount/total from the
// exact same line-item shape.
model Order {
  id              String         @id @default(uuid())
  customerId      String?
  customer        Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String // denormalized snapshot; survives customer deletion
  deliveryDate    DateTime
  paymentStatus   PaymentState         @default(UNPAID)
  deliveryStatus  DeliveryStatus       @default(SCHEDULED)
  fulfillmentType OrderFulfillmentType @default(SCHEDULED)
  paymentMethod   PaymentMethod        @default(CASH_ON_DELIVERY)
  deliveryAddress String?
  subtotal        Int
  discountAmount  Int                  @default(0)
  total           Int
  notes           String?
  items           OrderItem[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([customerId])
  @@index([deliveryDate])
  @@index([paymentStatus])
  @@index([fulfillmentType])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  // Snapshot of the menu item at order time — protects historical orders
  // from later menu price/flavor changes.
  protein   Protein
  flavor    String
  sizeGrams Int
  unitPrice Int
  qty       Int

  @@index([orderId])
  @@index([menuItemId])
}

// Volume-based subscription: the customer buys a total WEIGHT per protein
// up front (e.g. 30kg chicken + 10kg beef + 5kg shrimp — see
// SubscriptionPool), not a fixed portion-count template. They separately
// choose a delivery cadence (deliveryAmountGrams delivered every
// deliveryIntervalDays); the specific flavor for each occurrence is chosen
// closer to delivery time (see Delivery/DeliveryItem) and deducted from the
// matching protein's pool once that delivery is actually marked DELIVERED
// — never at scheduling time. This keeps balances accurate even though the
// schedule length isn't knowable exactly up front (postponing shifts it,
// and real package sizes don't divide evenly into deliveryAmountGrams).
//
// Deliveries are NOT all generated at creation time — only ones landing
// within the next 7 days are materialized (see SubscriptionsService.
// syncUpcomingDeliveries), keeping the Deliveries tab from being flooded
// with months of future placeholder rows.
model Subscription {
  id                   String             @id @default(uuid())
  customerId           String?
  customer             Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName         String // denormalized snapshot; survives customer deletion
  packageName          String
  totalGrams           Int // sum of pools' totalGrams at purchase time (fixed reference)
  deliveryAmountGrams  Int // target weight delivered per occurrence (across all proteins)
  deliveryIntervalDays Int // days between occurrences
  startDate            DateTime
  totalPrice           Int
  paymentStatus        PaymentState       @default(UNPAID)
  status               SubscriptionStatus @default(ACTIVE)
  postponedCount       Int                @default(0) // how many times a delivery has been postponed, for admin visibility

  pools      SubscriptionPool[] // one row per protein purchased, tracks remaining balance
  deliveries Delivery[] // the materialized (rolling 7-day-ahead) schedule

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

// One protein's purchased balance within a volume subscription — e.g.
// "30kg CHICKEN, 12.4kg remaining". remainingGrams only ever decreases when
// a Delivery containing items of this protein is marked DELIVERED
// (DeliveryService.markDelivered), never when a delivery is merely
// scheduled or postponed — that's what keeps postponing "conservative"
// (requirement: postponed amounts are preserved, not deducted).
model SubscriptionPool {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  protein        Protein
  totalGrams     Int
  remainingGrams Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@unique([subscriptionId, protein])
}

// One occurrence of a subscription's delivery schedule. Items are copied
// from SubscriptionItem at generation time so an individual delivery can
// later be tweaked (swapped item, different qty) without altering the
// subscription's template or other deliveries.
model Delivery {
  id             String         @id @default(uuid())
  subscriptionId String
  subscription   Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  scheduledDate  DateTime
  status         DeliveryStatus @default(SCHEDULED)
  notes          String?
  items          DeliveryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([scheduledDate])
  @@index([status])
}

model DeliveryItem {
  id         String    @id @default(uuid())
  deliveryId String
  delivery   Delivery  @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  protein   Protein
  flavor    String
  sizeGrams Int
  unitPrice Int
  qty       Int

  @@index([deliveryId])
  @@index([menuItemId])
}

// Coupon-style promo codes — not part of the migrated feature set yet (the
// current discount engine is fully computed, not code-based) but kept for
// a future promo-code feature.
model Discount {
  id        String   @id @default(uuid())
  code      String   @unique
  type      String // PERCENTAGE | FIXED
  amount    Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

// Ledger of actual payment transactions (future real payment processing).
// Distinct from Order.paymentStatus / Subscription.paymentStatus, which are
// the simple staff-tracked status shown in the UI today.
model Payment {
  id             String        @id @default(uuid())
  orderId        String?
  subscriptionId String?
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  transactionId  String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([orderId])
  @@index([subscriptionId])
  @@index([status])
}

model HomeFrame {
  id        String   @id @default(uuid())
  title     String?
  imageUrl  String
  linkUrl   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

