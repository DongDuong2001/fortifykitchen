# =========================================================================
# FortifyKitchen - Local Environment Template
# =========================================================================
# Copy this file to '.env' and '.env.local' and populate with your own values.
# Do NOT commit '.env' or '.env.local' to git!
# =========================================================================

# -------------------------------------------------------------------------
# Server Configurations
# -------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# -------------------------------------------------------------------------
# Database Settings
# -------------------------------------------------------------------------
# Local PostgreSQL fallback:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fortifykitchen?schema=public"
# Neon Database or Remote PostgreSQL URL:
DATABASE_URL="postgresql://[user]:[password]@[neon-hostname]/fortifykitchen?sslmode=require"

# -------------------------------------------------------------------------
# Authentication Secrets (Must be at least 32 characters for local dev)
# -------------------------------------------------------------------------
JWT_SECRET="generate-a-long-random-string-at-least-32-chars-long"
BETTER_AUTH_SECRET="generate-another-long-random-string-at-least-32-chars-long"
BETTER_AUTH_URL="http://localhost:4000"

# -------------------------------------------------------------------------
# Rate Limiting
# -------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -------------------------------------------------------------------------
# Frontend Variables (Shared between admin dashboard and customer web)
# -------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------------------------------------------------------------------------
# Cloudinary (Image Upload)
# -------------------------------------------------------------------------
# Get these from https://cloudinary.com/console → Settings → API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
